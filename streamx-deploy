# ═══════════════════════════════════════════════════════════════════════════════
#  COMMAND: deploy
# ═══════════════════════════════════════════════════════════════════════════════
cmd_deploy() {
  [[ ! -f "$DEPLOY_CFG" ]] && { err "Not in a streamx-deploy project. Run: streamx-deploy new"; exit 1; }

  local plat
  plat=$(python3 -c "import json; print(json.load(open('$DEPLOY_CFG')).get('platform',''))" 2>/dev/null || echo "")

  if [[ -z "$plat" ]]; then
    local choice
    choice=$(prompt_select "Choose platform:" \
      "☁️  Cloudflare Workers" "▲  Vercel" "⚙️  Render" "🚂 Railway" \
      "🌐 Netlify" "✈️  Fly.io" "🐳 Docker/VPS" "🍒 Cherry/VPS")
    case "$choice" in
      *Cloudflare*) plat="cloudflare" ;;
      *Vercel*)     plat="vercel"     ;;
      *Render*)     plat="render"     ;;
      *Railway*)    plat="railway"    ;;
      *Netlify*)    plat="netlify"    ;;
      *Fly*)        plat="fly"        ;;
      *)            plat="docker"     ;;
    esac
    json_set "$DEPLOY_CFG" "platform" "$plat"
  fi

  step "Deploying to ${plat}…"

  local deployed_url=""
  case "$plat" in
    cloudflare)
      has wrangler || { err "wrangler not found. Run: npm install -g wrangler && wrangler login"; exit 1; }
      wrangler deploy --env production
      deployed_url=$(wrangler deploy --dry-run 2>&1 | grep -o 'https://[^"]*\.workers\.dev' | head -1 || echo "")
      ;;
    vercel)
      has vercel || { err "vercel not found. Run: npm install -g vercel && vercel login"; exit 1; }
      deployed_url=$(vercel --prod --yes 2>&1 | grep -o 'https://[^ ]*\.vercel\.app' | head -1 || echo "")
      ;;
    railway)
      has railway || { err "railway not found. Run: npm install -g @railway/cli && railway login"; exit 1; }
      railway up --detach
      deployed_url=$(railway status 2>/dev/null | grep -o 'https://[^ ]*\.railway\.app' | head -1 || echo "")
      ;;
    netlify)
      has netlify || { err "netlify not found. Run: npm install -g netlify-cli && netlify login"; exit 1; }
      netlify deploy --prod
      deployed_url=$(netlify status 2>/dev/null | grep -o 'https://[^ ]*\.netlify\.app' | head -1 || echo "")
      ;;
    fly)
      has flyctl || { err "flyctl not found. Run: curl -L https://fly.io/install.sh | sh"; exit 1; }
      flyctl deploy
      deployed_url=$(flyctl status 2>/dev/null | grep -o 'https://[^ ]*\.fly\.dev' | head -1 || echo "")
      ;;
    render)
      info "Render deploys automatically on git push. Connect your repo at render.com"
      info "Push changes: git add . && git commit -m 'deploy' && git push"
      return 0
      ;;
    docker|vps|cherry*)
      if has docker; then
        step "Building Docker image…"
        docker build -t "streamx-addon:latest" .
        ok "Docker image built"
        echo
        info "To run locally:     docker compose up -d"
        info "To push to Docker Hub:"
        echo -e "  ${C}docker tag streamx-addon:latest YOUR_USER/streamx-addon:latest${NC}"
        echo -e "  ${C}docker push YOUR_USER/streamx-addon:latest${NC}"
        info "To deploy on VPS (SSH into server):"
        echo -e "  ${C}docker pull YOUR_USER/streamx-addon:latest${NC}"
        echo -e "  ${C}docker compose up -d --force-recreate${NC}"
      else
        warn "Docker not found. Install Docker first."
      fi
      return 0
      ;;
  esac

  if [[ -n "$deployed_url" ]]; then
    local manifest_url="${deployed_url%/}/manifest.json"
    json_set "$DEPLOY_CFG" "deployedUrl" "$manifest_url"
    ok "Deployed: ${W}${deployed_url}${NC}"
    echo
    _verify_live "$manifest_url"
    _print_install_guide "$manifest_url"
  else
    warn "Could not detect deployed URL. Check your platform dashboard."
  fi
}

# ═══════════════════════════════════════════════════════════════════════════════
#  COMMAND: test
# ═══════════════════════════════════════════════════════════════════════════════
cmd_test() {
  require_any
  local port="${1:-7070}" runner
  runner=$(js_runner)

  step "Testing addon on port ${port}"

  # Start server in background
  PORT="$port" $runner src/index.js &
  local pid=$!
  trap "kill $pid 2>/dev/null; exit" INT TERM EXIT
  sleep 2

  local base="http://127.0.0.1:${port}"
  local passed=0 failed=0

  _test_endpoint "manifest.json"       "GET" "$base/manifest.json"         "id"       && passed=$((passed+1)) || failed=$((failed+1))
  _test_endpoint "CORS headers"        "OPT" "$base/manifest.json"         "cors"     && passed=$((passed+1)) || failed=$((failed+1))
  _test_endpoint "stream (Godfather)"  "GET" "$base/stream/movie/tt0068646.json" "streams" && passed=$((passed+1)) || failed=$((failed+1))
  _test_endpoint "health check"        "GET" "$base/health"                "status"   && passed=$((passed+1)) || failed=$((failed+1))

  kill $pid 2>/dev/null
  trap - INT TERM EXIT

  echo
  if [[ $failed -eq 0 ]]; then
    ok "${G}All ${passed} tests passed!${NC}  Ready to deploy: ${C}streamx-deploy deploy${NC}"
  else
    warn "${passed} passed, ${R}${failed} failed${NC}.  Fix issues before deploying."
    return 1
  fi
}

_test_endpoint() {
  local label="$1" method="$2" url="$3" key="$4"
  local resp status
  if [[ "$method" == "OPT" ]]; then
    resp=$(curl -sI -X OPTIONS "$url" 2>/dev/null)
    echo "$resp" | grep -qi "access-control" && { ok "$label"; return 0; } || { err "$label (missing CORS)"; return 1; }
  else
    resp=$(curl -sf "$url" 2>/dev/null)
    [[ -n "$resp" ]] && echo "$resp" | grep -q "\"$key\"" && { ok "$label"; return 0; } || { err "$label"; return 1; }
  fi
}

# ═══════════════════════════════════════════════════════════════════════════════
#  COMMAND: validate
# ═══════════════════════════════════════════════════════════════════════════════
cmd_validate() {
  local url="$1"
  [[ -z "$url" ]] && {
    url=$(json_get "$DEPLOY_CFG" "deployedUrl" 2>/dev/null || echo "")
    [[ -z "$url" ]] && { err "Provide URL: streamx-deploy validate https://addon.vercel.app/manifest.json"; exit 1; }
  }
  [[ "$url" != *manifest.json ]] && url="${url%/}/manifest.json"

  step "Validating: ${url}"

  local manifest
  manifest=$(curl -sf --max-time 10 "$url") || { err "Cannot reach $url"; exit 1; }

  _check "manifest reachable"  true
  echo "$manifest" | grep -q '"id"'       && ok "has id"       || { err "missing id";       }
  echo "$manifest" | grep -q '"name"'     && ok "has name"     || { err "missing name";     }
  echo "$manifest" | grep -q '"version"'  && ok "has version"  || { err "missing version";  }
  echo "$manifest" | grep -q '"resources"' && ok "has resources" || { err "missing resources"; }

  # ID format
  local id
  id=$(echo "$manifest" | grep -o '"id"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"\([^"]*\)"/\1/')
  echo "$id" | grep -qE '^community\.[a-z0-9_-]+\.[a-z0-9_-]+$' \
    && ok "id format valid: ${id}" \
    || warn "id '${id}' should match community.author.name"

  # Stream test
  local base="${url%/manifest.json}"
  local streams
  streams=$(curl -sf --max-time 12 "${base}/stream/movie/tt0068646.json" 2>/dev/null) || streams='{"streams":[]}'
  echo "$streams" | grep -q '"streams"' && ok "stream endpoint valid" || err "stream endpoint invalid"

  # CORS
  curl -sI -X OPTIONS "$url" 2>/dev/null | grep -qi "access-control" \
    && ok "CORS headers present" || warn "CORS headers missing"

  echo
  ok "${G}Validation complete${NC}"
  _print_install_guide "$url"
}

_check() { ok "$1"; }

# ═══════════════════════════════════════════════════════════════════════════════
#  COMMAND: register
#  Submit to StreamX community registry
# ═══════════════════════════════════════════════════════════════════════════════
cmd_register() {
  local url
  url=$(json_get "$DEPLOY_CFG" "deployedUrl" 2>/dev/null || echo "")
  [[ -z "$url" ]] && {
    url=$(prompt "Deployed manifest URL")
    [[ "$url" != *manifest.json ]] && url="${url%/}/manifest.json"
  }

  step "Fetching addon manifest…"
  local manifest
  manifest=$(curl -sf --max-time 10 "$url") || { err "Cannot reach $url"; exit 1; }

  local id name version desc logo types resources
  id=$(echo "$manifest"       | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('id',''))")
  name=$(echo "$manifest"     | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('name',''))")
  version=$(echo "$manifest"  | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('version','1.0.0'))")
  desc=$(echo "$manifest"     | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('description',''))")
  logo=$(echo "$manifest"     | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('logo',''))")
  types=$(echo "$manifest"    | python3 -c "import json,sys; d=json.load(sys.stdin); print(json.dumps(d.get('types',[])))")
  resources=$(echo "$manifest"| python3 -c "import json,sys; d=json.load(sys.stdin); print(json.dumps([r if isinstance(r,str) else r.get('name','') for r in d.get('resources',[])]))")

  local nsfw
  nsfw=$(prompt "Is this addon NSFW? (adult content)" "no")
  [[ "$nsfw" =~ ^[Yy] ]] && nsfw_val="true" || nsfw_val="false"

  # Build registry entry JSON
  local entry
  entry=$(python3 << PYEOF
import json
entry = {
  "manifest": {
    "id": "${id}",
    "version": "${version}",
    "name": "${name}",
    "description": "${desc}",
    "logo": "${logo}",
    "types": ${types},
    "resources": ${resources},
    "idPrefixes": ["tt"],
    "catalogs": []
  },
  "transportUrl": "${url}",
  "kind": "HTTP_ENDPOINT",
  "flags": { "official": False, "verified": False, "nsfw": ${nsfw_val} }
}
print(json.dumps(entry, indent=2))
PYEOF
)

  step "Your registry entry:"
  echo -e "${C}${entry}${NC}"
  echo

  # Open GitHub PR URL
  local encoded_body
  encoded_body=$(python3 -c "import urllib.parse; print(urllib.parse.quote('## Addon Submission\n\n\`\`\`json\n${entry}\n\`\`\`\n\nI confirm this addon will remain 24/7 available.'))")
  local pr_url="${REGISTRY_REPO}/compare/main...main?quick_pull=1&title=$(python3 -c "import urllib.parse; print(urllib.parse.quote('[Addon] ${name}'))")&body=${encoded_body}"

  step "Submit to StreamX Registry:"
  echo -e "  1. Fork: ${C}${REGISTRY_REPO}${NC}"
  echo -e "  2. Add the JSON above to ${W}registry.json${NC}"
  echo -e "  3. Open a Pull Request — the bot will auto-validate\n"
  echo -e "  Or open this pre-filled PR link:\n  ${DIM}${pr_url}${NC}"
  echo
  info "After merge, your addon appears on the catalog website within minutes."

  # Try to open browser
  has xdg-open && xdg-open "$pr_url" 2>/dev/null || \
  has open     && open "$pr_url" 2>/dev/null || \
  info "Copy the URL above and open in your browser."
}

