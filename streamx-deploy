# ── Write platform config files ────────────────────────────────────────────────
_write_platform_config() {
  local plat="$1" name="$2" id="$3" display="$4"

  case "$plat" in
    cloudflare)
      cat > wrangler.toml << EOF
name               = "${name}"
main               = "src/index.js"
compatibility_date = "2024-01-01"

[vars]
ADDON_ID      = "${id}"
ADDON_VERSION = "1.0.0"
ADDON_NAME    = "${display}"
ADDON_DESC    = "StreamX community addon"

# Secrets (never put in vars):
# wrangler secret put MY_API_KEY

[env.production]
name = "${name}-prod"
EOF
      ;;
    vercel)
      cat > vercel.json << EOF
{
  "version": 2,
  "builds": [{ "src": "src/index.js", "use": "@vercel/node" }],
  "routes": [{ "src": "/(.*)", "dest": "src/index.js" }],
  "env": {
    "ADDON_ID":   "${id}",
    "ADDON_NAME": "${display}"
  }
}
EOF
      ;;
    netlify)
      mkdir -p netlify/functions
      cat > netlify.toml << 'EOF'
[build]
  command   = "npm install"
  functions = "netlify/functions"

[[redirects]]
  from   = "/*"
  to     = "/.netlify/functions/addon/:splat"
  status = 200
EOF
      # Create Netlify function wrapper
      cat > netlify/functions/addon.mjs << 'EOF'
import { app } from '../../src/index.js'
import serverless from 'serverless-http'
export const handler = serverless(app)
EOF
      ;;
    fly)
      cat > fly.toml << EOF
app = "${name}"
primary_region = "sin"

[build]

[http_service]
  internal_port = 7000
  force_https   = true
  [[http_service.ports]]
    port = 443

[env]
  ADDON_ID   = "${id}"
  ADDON_NAME = "${display}"
  PORT       = "7000"
EOF
      ;;
    docker|vps|cherry*)
      cat > Dockerfile << 'EOF'
FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production
COPY . .
EXPOSE 7000
ENV PORT=7000
HEALTHCHECK --interval=30s --timeout=10s CMD wget -qO- http://localhost:7000/health || exit 1
CMD ["node", "src/index.js"]
EOF
      cat > docker-compose.yml << EOF
services:
  addon:
    build: .
    restart: unless-stopped
    ports:
      - "7000:7000"
    environment:
      - PORT=7000
      - ADDON_ID=${id}
      - ADDON_NAME=${display}
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:7000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
EOF
      # Caddyfile for HTTPS on VPS
      cat > Caddyfile << 'EOF'
# Replace your-domain.com with actual domain
your-domain.com {
  reverse_proxy addon:7000
}
EOF
      ;;
    render)
      cat > render.yaml << EOF
services:
  - type: web
    name: ${name}
    env: node
    buildCommand: npm install
    startCommand: node src/index.js
    envVars:
      - key: PORT
        value: 10000
      - key: ADDON_ID
        value: ${id}
      - key: ADDON_NAME
        value: ${display}
EOF
      ;;
    railway)
      mkdir -p .railway
      cat > .railway/Procfile << 'EOF'
web: node src/index.js
EOF
      ;;
  esac
}

# ── Write GitHub Actions ───────────────────────────────────────────────────────
_write_github_action() {
  local plat="$1"
  case "$plat" in
    cloudflare)
      cat > .github/workflows/deploy.yml << 'EOF'
name: Deploy to Cloudflare Workers
on:
  push:
    branches: [main]
  workflow_dispatch:
jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: cloudflare/wrangler-action@v3
        with:
          apiToken:  ${{ secrets.CF_API_TOKEN }}
          accountId: ${{ secrets.CF_ACCOUNT_ID }}
          command:   deploy --env production
      - name: Verify live
        run: |
          sleep 5
          curl -sf "${WORKER_URL}/manifest.json" && echo "✅ Live" || echo "⚠️ Not responding yet"
        env:
          WORKER_URL: ${{ vars.WORKER_URL }}
EOF
      ;;
    vercel)
      cat > .github/workflows/deploy.yml << 'EOF'
name: Deploy to Vercel
on:
  push:
    branches: [main]
jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: { node-version: '20' }
      - run: npm ci
      - run: npx vercel --token=${{ secrets.VERCEL_TOKEN }} --prod --yes
        env:
          VERCEL_ORG_ID:     ${{ secrets.VERCEL_ORG_ID }}
          VERCEL_PROJECT_ID: ${{ secrets.VERCEL_PROJECT_ID }}
EOF
      ;;
    render)
      cat > .github/workflows/deploy.yml << 'EOF'
name: Trigger Render Deploy
on:
  push:
    branches: [main]
jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Trigger deploy
        run: curl -fsX POST "${{ secrets.RENDER_DEPLOY_HOOK }}"
EOF
      ;;
    railway)
      cat > .github/workflows/deploy.yml << 'EOF'
name: Deploy to Railway
on:
  push:
    branches: [main]
jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: bervProject/railway-deploy@main
        with:
          railway_token: ${{ secrets.RAILWAY_TOKEN }}
          service:       ${{ secrets.RAILWAY_SERVICE }}
EOF
      ;;
    fly)
      cat > .github/workflows/deploy.yml << 'EOF'
name: Deploy to Fly.io
on:
  push:
    branches: [main]
jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: superfly/flyctl-actions/setup-flyctl@master
      - run: flyctl deploy --remote-only
        env:
          FLY_API_TOKEN: ${{ secrets.FLY_API_TOKEN }}
EOF
      ;;
    docker|vps|cherry*)
      cat > .github/workflows/deploy.yml << 'EOF'
name: Deploy to VPS via Docker
on:
  push:
    branches: [main]
jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKERHUB_USER }}
          password: ${{ secrets.DOCKERHUB_TOKEN }}
      - uses: docker/build-push-action@v5
        with:
          push: true
          tags: ${{ secrets.DOCKERHUB_USER }}/streamx-addon:latest
      - uses: appleboy/ssh-action@v1
        with:
          host:     ${{ secrets.VPS_HOST }}
          username: ${{ secrets.VPS_USER }}
          key:      ${{ secrets.VPS_SSH_KEY }}
          script: |
            docker pull ${{ secrets.DOCKERHUB_USER }}/streamx-addon:latest
            cd /opt/streamx-addon && docker compose up -d --force-recreate
            echo "✅ Deployed"
EOF
      ;;
    *)
      cat > .github/workflows/deploy.yml << 'EOF'
name: Deploy
on:
  push:
    branches: [main]
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with: { node-version: '20' }
      - run: npm ci && npm test
EOF
      ;;
  esac
}

