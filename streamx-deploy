#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════════════════
#  streamx-deploy  v2.0
#  Ultimate StreamX / Stremio addon deploy tool
#
#  Install:
#    curl -sSL https://aeoncorex-lab.github.io/streamx-deploy/install.sh | bash
#
#  Or manually:
#    curl -sSL https://aeoncorex-lab.github.io/streamx-deploy/streamx-deploy -o streamx-deploy
#    chmod +x streamx-deploy && sudo mv streamx-deploy /usr/local/bin/
#
#  Commands:
#    streamx-deploy new              → scaffold addon project (interactive)
#    streamx-deploy deploy           → deploy to any platform (interactive)
#    streamx-deploy test             → test endpoints locally
#    streamx-deploy validate <url>   → validate live addon
#    streamx-deploy register         → submit to StreamX registry
#    streamx-deploy platforms        → show all supported platforms
#    streamx-deploy update           → update this tool
# ═══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

# ── Config ─────────────────────────────────────────────────────────────────────
VERSION="2.0.0"
REGISTRY_REPO="https://github.com/YOUR_GITHUB_USERNAME/streamx-addons"
REGISTRY_API="https://aeoncorex-lab.github.io/streamx-addons/registry.json"
TEMPLATE_BASE="https://aeoncorex-lab.github.io/streamx-deploy/templates"
DEPLOY_CFG=".streamx-deploy.json"

# ── Colours ────────────────────────────────────────────────────────────────────
R='\033[0;31m' G='\033[0;32m' Y='\033[1;33m'
B='\033[0;34m' C='\033[0;36m' M='\033[0;35m'
W='\033[1;37m' DIM='\033[2m'  NC='\033[0m'
BOLD='\033[1m'

ok()   { echo -e "${G}✓${NC}  $*"; }
err()  { echo -e "${R}✗${NC}  $*" >&2; }
warn() { echo -e "${Y}⚠${NC}  $*"; }
info() { echo -e "${C}›${NC}  $*"; }
step() { echo -e "\n${BOLD}${W}$*${NC}"; }
dim()  { echo -e "${DIM}$*${NC}"; }

# ── Banner ─────────────────────────────────────────────────────────────────────
banner() {
  echo -e "${C}"
  cat << 'EOF'
  ╔══════════════════════════════════════════════════╗
  ║   StreamX Deploy  —  Addon Deploy Tool v2.0      ║
  ║   Deploy anywhere. Register once. Run forever.   ║
  ╚══════════════════════════════════════════════════╝
EOF
  echo -e "${NC}"
}

# ── Dependency check ───────────────────────────────────────────────────────────
has() { command -v "$1" &>/dev/null; }

require_any() {
  # At least one of: node, bun, deno
  has node || has bun || has deno || {
    err "No JavaScript runtime found. Install Node.js, Bun, or Deno."
    echo "  Node.js: https://nodejs.org"
    echo "  Bun:     curl -fsSL https://bun.sh/install | bash"
    exit 1
  }
}

js_runner() {
  if   has bun;  then echo "bun"
  elif has node; then echo "node"
  elif has deno; then echo "deno run --allow-all"
  fi
}

# ── JSON helpers (pure bash, no jq needed) ────────────────────────────────────
json_get() {
  # json_get <file> <key>  — simple key extraction without jq
  local file="$1" key="$2"
  grep -o "\"${key}\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" "$file" 2>/dev/null \
    | head -1 | sed 's/.*":\s*"\(.*\)"/\1/'
}

json_set() {
  # Update a key in a JSON file using python (available everywhere)
  local file="$1" key="$2" val="$3"
  python3 -c "
import json, sys
with open('$file') as f: d = json.load(f)
d['$key'] = '$val'
with open('$file', 'w') as f: json.dump(d, f, indent=2)
" 2>/dev/null || true
}

# ── Platform detection ─────────────────────────────────────────────────────────
detect_platforms() {
  local avail=()
  has wrangler        && avail+=("cloudflare")
  has vercel          && avail+=("vercel")
  has railway         && avail+=("railway")
  has netlify         && avail+=("netlify")
  has flyctl          && avail+=("fly")
  has docker          && avail+=("docker")
  has ssh             && avail+=("vps")
  echo "${avail[@]:-none}"
}

# ── Interactive prompt ─────────────────────────────────────────────────────────
prompt() {
  local msg="$1" default="${2:-}" var
  if [[ -n "$default" ]]; then
    echo -ne "${W}${msg}${NC} ${DIM}[${default}]${NC}: "
  else
    echo -ne "${W}${msg}${NC}: "
  fi
  read -r var
  echo "${var:-$default}"
}

prompt_select() {
  local msg="$1"; shift
  local opts=("$@")
  echo -e "\n${W}${msg}${NC}"
  for i in "${!opts[@]}"; do
    echo -e "  ${C}$((i+1))${NC}. ${opts[$i]}"
  done
  echo -ne "\n${W}Choice${NC} [1]: "
  local choice; read -r choice
  choice="${choice:-1}"
  echo "${opts[$((choice-1))]}"
}

# ═══════════════════════════════════════════════════════════════════════════════
#  COMMAND: new
#  Scaffold a new addon project from template
# ═══════════════════════════════════════════════════════════════════════════════
cmd_new() {
  banner
  step "Create New StreamX Addon"

  local name id display_name desc platform

  name=$(prompt "Project directory name (lowercase, hyphens)" "my-addon")
  id=$(prompt "Addon ID (community.author.name format)" "community.myname.${name}")
  display_name=$(prompt "Display name" "${name^}")
  desc=$(prompt "Short description" "StreamX community addon")

  # Platform choice
  platform=$(prompt_select "Target platform:" \
    "☁️  Cloudflare Workers  (free, global CDN, recommended)" \
    "▲  Vercel              (free, serverless)" \
    "⚙️  Render              (free tier, may sleep)" \
    "🚂 Railway             (\$5 free credit/month)" \
    "🌐 Netlify Functions   (free tier)" \
    "✈️  Fly.io              (free tier)" \
    "🐳 Docker / VPS        (self-hosted, full control)" \
    "🍒 Cherry Servers      (dedicated server, SSH+Docker)"
  )

  # Map display to key
  case "$platform" in
    *Cloudflare*) PLAT="cloudflare" ;;
    *Vercel*)     PLAT="vercel"     ;;
    *Render*)     PLAT="render"     ;;
    *Railway*)    PLAT="railway"    ;;
    *Netlify*)    PLAT="netlify"    ;;
    *Fly*)        PLAT="fly"        ;;
    *Cherry*)     PLAT="vps"        ;;
    *)            PLAT="docker"     ;;
  esac

  [[ -d "$name" ]] && { err "Directory '$name' already exists"; exit 1; }
  mkdir -p "$name/src"
  cd "$name"

  step "Generating project files…"

  # ── manifest.json ─────────────────────────────────────────────────────────
  cat > manifest.json << EOF
{
  "id":          "${id}",
  "version":     "1.0.0",
  "name":        "${display_name}",
  "description": "${desc}",
  "logo":        "",
  "types":       ["movie", "series"],
  "resources":   ["stream"],
  "idPrefixes":  ["tt"],
  "catalogs":    []
}
EOF

  # ── package.json ──────────────────────────────────────────────────────────
  cat > package.json << EOF
{
  "name": "${name}",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start":    "node src/index.js",
    "dev":      "node --watch src/index.js",
    "test":     "streamx-deploy test",
    "deploy":   "streamx-deploy deploy",
    "register": "streamx-deploy register"
  },
  "dependencies": { "cors": "^2.8.5", "express": "^4.19.2" },
  "engines": { "node": ">=18" }
}
EOF

  # ── .streamx-deploy.json ──────────────────────────────────────────────────
  cat > .streamx-deploy.json << EOF
{
  "addonId":     "${id}",
  "addonName":   "${display_name}",
  "addonDesc":   "${desc}",
  "platform":    "${PLAT}",
  "createdAt":   "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF

  # ── .env.example ──────────────────────────────────────────────────────────
  cat > .env.example << 'EOF'
# Add your API keys here (never commit .env)
# ADDON_ID=community.myname.myaddon
# MY_API_KEY=
EOF

  # ── .gitignore ────────────────────────────────────────────────────────────
  cat > .gitignore << 'EOF'
node_modules/
.env
.wrangler/
.vercel/
dist/
*.log
EOF

  # ── src/index.js ──────────────────────────────────────────────────────────
  _write_addon_template "$PLAT" "$id" "$display_name" "$desc"

  # ── Platform-specific files ────────────────────────────────────────────────
  _write_platform_config "$PLAT" "$name" "$id" "$display_name"

  # ── GitHub Actions ────────────────────────────────────────────────────────
  mkdir -p .github/workflows
  _write_github_action "$PLAT"

  ok "Project created: ${W}${name}/${NC}"
  echo
  echo -e "${BOLD}Next steps:${NC}"
  echo -e "  ${C}cd ${name}${NC}"
  echo -e "  ${C}npm install${NC}"
  echo -e "  ${Y}# Edit src/index.js → fill in getStreams()${NC}"
  echo -e "  ${C}streamx-deploy test${NC}        ${DIM}# test locally${NC}"
  echo -e "  ${C}streamx-deploy deploy${NC}      ${DIM}# deploy to ${PLAT}${NC}"
  echo -e "  ${C}streamx-deploy register${NC}    ${DIM}# submit to StreamX registry${NC}"
  echo
  _print_platform_setup "$PLAT"
}

