# ═══════════════════════════════════════════════════════════════════════════════
#  COMMAND: update
# ═══════════════════════════════════════════════════════════════════════════════
cmd_update() {
  step "Updating streamx-deploy…"
  local install_path
  install_path=$(which streamx-deploy 2>/dev/null || echo "/usr/local/bin/streamx-deploy")
  curl -sSL "https://aeoncorex-lab.github.io/streamx-deploy/streamx-deploy" -o "$install_path"
  chmod +x "$install_path"
  ok "Updated to latest version"
}

# ── Helpers ────────────────────────────────────────────────────────────────────
_verify_live() {
  local url="$1"
  info "Verifying live endpoint…"
  sleep 3
  curl -sf --max-time 10 "$url" &>/dev/null \
    && ok "Live and responding" \
    || warn "Not responding yet. May take up to 30 seconds to start."
}

_print_install_guide() {
  local url="$1"
  echo -e "\n${BOLD}Install in StreamX:${NC}"
  echo -e "  ${Y}Settings → Addons → 🔗 → paste:${NC}"
  echo -e "  ${C}${url}${NC}"
  echo
  echo -e "  ${DIM}Deeplink: streamx://install-addon?url=$(python3 -c "import urllib.parse; print(urllib.parse.quote('${url}'))" 2>/dev/null || echo "${url}")${NC}"
  echo
}

# ═══════════════════════════════════════════════════════════════════════════════
#  Main dispatcher
# ═══════════════════════════════════════════════════════════════════════════════
main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    new|init|create)  cmd_new        "$@" ;;
    deploy|push)      cmd_deploy     "$@" ;;
    test|dev)         cmd_test       "$@" ;;
    validate|check)   cmd_validate   "$@" ;;
    register|publish) cmd_register   "$@" ;;
    platforms|list)   cmd_platforms       ;;
    update|upgrade)   cmd_update          ;;
    version|-v|--version) echo "streamx-deploy v${VERSION}" ;;
    help|-h|--help|*)
      banner
      echo -e "${BOLD}Usage:${NC}  streamx-deploy <command>\n"
      echo -e "  ${C}new${NC}              Scaffold new addon project (interactive)"
      echo -e "  ${C}deploy${NC}           Deploy to your chosen platform"
      echo -e "  ${C}test${NC}             Test endpoints locally"
      echo -e "  ${C}validate${NC} [url]   Validate a live addon URL"
      echo -e "  ${C}register${NC}         Submit to StreamX community registry"
      echo -e "  ${C}platforms${NC}        Show supported platforms"
      echo -e "  ${C}update${NC}           Update this tool\n"
      echo -e "${DIM}Install: curl -sSL https://aeoncorex-lab.github.io/streamx-deploy/install.sh | bash${NC}\n"
      ;;
  esac
}

main "$@"
