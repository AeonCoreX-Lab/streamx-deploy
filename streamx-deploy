  _platform_row() {
    local key="$1" name="$2" cost="$3" notes="$4"
    local cli_status
    echo "$available" | grep -q "$key" \
      && cli_status="${G}✓ CLI installed${NC}" \
      || cli_status="${DIM}CLI not installed${NC}"
    printf "  ${C}%-12s${NC} ${W}%-20s${NC} %-22s %b\n" "$key" "$name" "$cost" "$cli_status"
  }

  _platform_row "cloudflare" "Cloudflare Workers" "Free (100k req/day)"  ""
  _platform_row "vercel"     "Vercel"             "Free (100GB/month)"   ""
  _platform_row "netlify"    "Netlify Functions"  "Free (125k req/month)" ""
  _platform_row "render"     "Render"             "Free (sleeps 15min)"  ""
  _platform_row "fly"        "Fly.io"             "Free tier available"  ""
